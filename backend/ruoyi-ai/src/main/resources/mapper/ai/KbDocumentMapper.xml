<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.aiplatform.ai.mapper.KbDocumentMapper">

    <resultMap type="KbDocument" id="KbDocumentResult">
        <id     property="docId"           column="doc_id"            />
        <result property="kbId"            column="kb_id"             />
        <result property="fileName"        column="file_name"         />
        <result property="fileType"        column="file_type"         />
        <result property="fileSize"        column="file_size"         />
        <result property="filePath"        column="file_path"         />
        <result property="contentText"     column="content_text"      />
        <result property="chunkCount"      column="chunk_count"       />
        <result property="vectorIds"       column="vector_ids"        />
        <result property="status"          column="status"            />
        <result property="errorMsg"        column="error_msg"         />
        <result property="isDelete"        column="is_delete"         />
        <result property="createBy"        column="create_by"         />
        <result property="createTime"      column="create_time"       />
        <result property="updateBy"        column="update_by"         />
        <result property="updateTime"      column="update_time"       />
        <result property="remark"          column="remark"            />
    </resultMap>

    <sql id="selectDocumentVo">
        select doc_id, kb_id, file_name, file_type, file_size, file_path,
               content_text, chunk_count, vector_ids, status, error_msg, is_delete,
               create_by, create_time, update_by, update_time, remark
        from kb_document
    </sql>

    <select id="selectDocument" parameterType="KbDocument" resultMap="KbDocumentResult">
        <include refid="selectDocumentVo"/>
        <where>
            <if test="docId != null">and doc_id = #{docId}</if>
        </where>
    </select>

    <select id="selectDocumentList" parameterType="KbDocument" resultMap="KbDocumentResult">
        <include refid="selectDocumentVo"/>
        <where>
            <if test="kbId != null">AND kb_id = #{kbId}</if>
            <if test="fileName != null and fileName != ''">AND file_name like concat('%', #{fileName}, '%')</if>
            <if test="fileType != null and fileType != ''">AND file_type = #{fileType}</if>
            <if test="status != null">AND status = #{status}</if>
        </where>
        order by create_time desc
    </select>

    <select id="selectDocumentsByKbId" parameterType="Long" resultMap="KbDocumentResult">
        <include refid="selectDocumentVo"/>
        where kb_id = #{kbId}
        order by create_time desc
    </select>

    <select id="selectDocumentById" parameterType="Long" resultMap="KbDocumentResult">
        <include refid="selectDocumentVo"/>
        where doc_id = #{docId}
    </select>

    <insert id="insertDocument" parameterType="KbDocument">
        insert into kb_document (
            <if test="kbId != null">kb_id,</if>
            <if test="fileName != null and fileName != ''">file_name,</if>
            <if test="fileType != null and fileType != ''">file_type,</if>
            <if test="fileSize != null">file_size,</if>
            <if test="filePath != null and filePath != ''">file_path,</if>
            <if test="contentText != null">content_text,</if>
            <if test="chunkCount != null">chunk_count,</if>
            <if test="vectorIds != null">vector_ids,</if>
            <if test="status != null">status,</if>
            <if test="errorMsg != null">error_msg,</if>
            <if test="isDelete != null">is_delete,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="remark != null and remark != ''">remark,</if>
            create_time
        ) values (
            <if test="kbId != null">#{kbId},</if>
            <if test="fileName != null and fileName != ''">#{fileName},</if>
            <if test="fileType != null and fileType != ''">#{fileType},</if>
            <if test="fileSize != null">#{fileSize},</if>
            <if test="filePath != null and filePath != ''">#{filePath},</if>
            <if test="contentText != null">#{contentText},</if>
            <if test="chunkCount != null">#{chunkCount},</if>
            <if test="vectorIds != null">#{vectorIds},</if>
            <if test="status != null">#{status},</if>
            <if test="errorMsg != null">#{errorMsg},</if>
            <if test="isDelete != null">#{isDelete},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
            sysdate()
        )
    </insert>

    <update id="updateDocument" parameterType="KbDocument">
        update kb_document
        <set>
            <if test="fileName != null and fileName != ''">file_name = #{fileName},</if>
            <if test="fileType != null">file_type = #{fileType},</if>
            <if test="fileSize != null">file_size = #{fileSize},</if>
            <if test="filePath != null">file_path = #{filePath},</if>
            <if test="contentText != null">content_text = #{contentText},</if>
            <if test="chunkCount != null">chunk_count = #{chunkCount},</if>
            <if test="vectorIds != null">vector_ids = #{vectorIds},</if>
            <if test="status != null">status = #{status},</if>
            <if test="errorMsg != null">error_msg = #{errorMsg},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </set>
        where doc_id = #{docId}
    </update>

    <update id="deleteDocumentById" parameterType="Long">
        update kb_document set is_delete = 1 where doc_id = #{docId}
    </update>

    <update id="deleteDocumentByIds" parameterType="Long">
        update kb_document set is_delete = 1 where doc_id in
        <foreach collection="array" item="docId" open="(" separator="," close=")">
            #{docId}
        </foreach>
    </update>

</mapper>