<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.aiplatform.ai.mapper.AiConversationMapper">

    <resultMap type="AiConversation" id="AiConversationResult">
        <id     property="conversationId"   column="conversation_id"   />
        <result property="userId"           column="user_id"           />
        <result property="title"            column="title"             />
        <result property="agentType"        column="agent_type"        />
        <result property="agentId"          column="agent_id"          />
        <result property="modelId"          column="model_id"          />
        <result property="status"           column="status"            />
        <result property="createBy"         column="create_by"         />
        <result property="createTime"       column="create_time"       />
        <result property="updateBy"         column="update_by"         />
        <result property="updateTime"       column="update_time"       />
        <result property="remark"           column="remark"            />
    </resultMap>

    <sql id="selectConversationVo">
        select conversation_id, user_id, title, agent_type, agent_id, model_id, status,
               create_by, create_time, update_by, update_time, remark
        from ai_conversation
    </sql>

    <select id="selectConversation" parameterType="AiConversation" resultMap="AiConversationResult">
        <include refid="selectConversationVo"/>
        <where>
            <if test="conversationId != null">and conversation_id = #{conversationId}</if>
            <if test="userId != null">and user_id = #{userId}</if>
        </where>
    </select>

    <select id="selectConversationList" parameterType="AiConversation" resultMap="AiConversationResult">
        <include refid="selectConversationVo"/>
        <where>
            <if test="userId != null">AND user_id = #{userId}</if>
            <if test="title != null and title != ''">AND title like concat('%', #{title}, '%')</if>
            <if test="agentType != null and agentType != ''">AND agent_type = #{agentType}</if>
            <if test="status != null">AND status = #{status}</if>
        </where>
        order by update_time desc
    </select>

    <select id="selectConversationById" parameterType="Long" resultMap="AiConversationResult">
        <include refid="selectConversationVo"/>
        where conversation_id = #{conversationId}
    </select>

    <insert id="insertConversation" parameterType="AiConversation" useGeneratedKeys="true" keyProperty="conversationId">
        insert into ai_conversation (
            <if test="userId != null">user_id,</if>
            <if test="title != null and title != ''">title,</if>
            <if test="agentType != null and agentType != ''">agent_type,</if>
            <if test="agentId != null">agent_id,</if>
            <if test="modelId != null">model_id,</if>
            <if test="status != null">status,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="remark != null and remark != ''">remark,</if>
            create_time
        ) values (
            <if test="userId != null">#{userId},</if>
            <if test="title != null and title != ''">#{title},</if>
            <if test="agentType != null and agentType != ''">#{agentType},</if>
            <if test="agentId != null">#{agentId},</if>
            <if test="modelId != null">#{modelId},</if>
            <if test="status != null">#{status},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
            sysdate()
        )
    </insert>

    <update id="updateConversation" parameterType="AiConversation">
        update ai_conversation
        <set>
            <if test="title != null and title != ''">title = #{title},</if>
            <if test="agentType != null and agentType != ''">agent_type = #{agentType},</if>
            <if test="agentId != null">agent_id = #{agentId},</if>
            <if test="modelId != null">model_id = #{modelId},</if>
            <if test="status != null">status = #{status},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </set>
        where conversation_id = #{conversationId}
    </update>

    <delete id="deleteConversationById" parameterType="Long">
        delete from ai_conversation where conversation_id = #{conversationId}
    </delete>

    <delete id="deleteConversationByIds" parameterType="Long">
        delete from ai_conversation where conversation_id in
        <foreach collection="array" item="conversationId" open="(" separator="," close=")">
            #{conversationId}
        </foreach>
    </delete>

</mapper>